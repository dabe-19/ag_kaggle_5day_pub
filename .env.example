# Server Configuration
PORT=8000
HOST=0.0.0.0

# Security (Leave empty if you want users to supply their own API keys via the Web UI)
# IMPORTANT: Do NOT wrap values in quotes — Docker Compose env_file passes them verbatim.
# Correct:   GEMINI_API_KEY=AIza...
# Incorrect: GEMINI_API_KEY="AIza..."
GEMINI_API_KEY=
GEMINI_API_KEY_BACKUP=
GEMINI_API_KEY_TERTIARY=
GEMINI_API_KEY_QUATERNARY=
GEMINI_API_KEY_QUINARY=

# Twitch Helix API (required for real concurrent Twitch viewer counts)
# Register a free app at https://dev.twitch.tv/console
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# YouTube Data API v3 (required for real concurrent YouTube viewer counts)
# Enable at https://console.cloud.google.com/apis/library/youtube.googleapis.com
# Free quota: 10,000 units/day
YOUTUBE_API_KEY=

# Docker / Cloud Run deployment
# Required only when building/pushing the image for Cloud Run
GCP_PROJECT=your-gcp-project-id
IMAGE_TAG=latest
